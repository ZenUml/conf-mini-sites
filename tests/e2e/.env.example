# tests/e2e/.env.example — env var NAMES consumed by the Playwright E2E suite (see
# tests/e2e/helpers/env.ts). Copy to tests/e2e/.env, fill in values, and source it before running.
# tests/e2e/.env is gitignored — NEVER commit real values. Values below are intentionally EMPTY.
#
# USAGE — there is NO dotenv dependency in this repo (env.ts reads process.env directly), so nothing
# auto-loads this file. Source it into your shell first, then run playwright:
#   set -a; source tests/e2e/.env; set +a
#   pnpm exec playwright test
# (Do NOT add `import 'dotenv/config'` to the suite — dotenv is not a dependency and adding it would
#  break `pnpm install --frozen-lockfile`.)

# ── Secrets / credentials (required only by the specs that use them; env.ts getters are lazy) ────
# CONTROL_SHARED_SECRET — must equal the remote/control Worker's CONTROL_SHARED_SECRET. The `api`
# project (testMatch api/*.spec.ts) sends it to hit the deployed control Worker — this is the
# always-on CI gate (no browser, no login).
CONTROL_SHARED_SECRET=
# FORGE_EMAIL / FORGE_API_TOKEN — Atlassian account email + API token, for Forge/Confluence REST.
FORGE_EMAIL=
FORGE_API_TOKEN=
# ZENUML_STAGE_USERNAME / ZENUML_STAGE_PASSWORD — Atlassian login used by the `setup`/`ui` projects.
ZENUML_STAGE_USERNAME=
ZENUML_STAGE_PASSWORD=
# ATLASSIAN_OTP — TOTP secret (the seed, not a 6-digit code) for the login's 2FA step.
ATLASSIAN_OTP=

# ── Optional overrides (defaults shown in comments; leave unset to use the dev stack defaults) ───
# E2E_SITE            default: lite-dev.atlassian.net   (login probes baseUrl + /wiki)
# E2E_SPACE_KEY       default: SD
# E2E_SPACE_ID        default: 196754
# E2E_CLOUD_ID        default: bc8bb5b3-09d2-4932-b68c-9b56fab8e34a
# E2E_FORGE_APP_ID    default: 2efdb7d9-ee5a-4294-b56a-b514e36e1a98
# E2E_FORGE_ENV_ID    default: f69f8404-376e-4a05-9d34-c8d53785db66
# CONTROL_URL         default: https://conf-mini-sites-remote-dev.zenuml.workers.dev
# DISPATCH_URL        default: https://conf-mini-sites-dispatch-dev.zenuml.workers.dev
